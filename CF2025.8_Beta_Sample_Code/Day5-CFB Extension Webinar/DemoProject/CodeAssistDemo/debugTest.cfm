<cfscript>
    // Step 1: Define variables
    a = 10;
    b = 20;

    // Step 2: Perform calculation
    sum = a + b;

    // Step 3: Conditional logic
    if (sum GT 25) {
        message = "Sum is greater than 25";
    } else {
        message = "Sum is 25 or less";
    }

    // Step 4: Output
    writeOutput(message);
</cfscript>
